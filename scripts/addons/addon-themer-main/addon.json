{
    "id": "addon-themer",
    "name": "fxPanel Themer",
    "description": "Edit the fxPanel web panel and in-game menu with custom colors and logos.",
    "version": "1.0.2",
    "author": "entytaiment25",
    "license": "MIT",
    "fxpanel": {
        "minVersion": "0.1.1-Beta"
    },
    "permissions": {
        "required": [],
        "optional": []
    },
    "server": {
        "entry": "server/index.js"
    },
    "panel": {
        "entry": "panel/index.js",
        "styles": "panel/index.css",
        "pages": [
            {
                "path": "/theme-editor",
                "title": "Theme Editor",
                "icon": "Palette",
                "sidebar": true,
                "sidebarGroup": "Settings",
                "permission": "all_permissions",
                "component": "ThemeEditorPage"
            }
        ],
        "widgets": []
    },
    "nui": {
        "entry": "nui/index.js",
        "styles": "nui/index.css",
        "pages": []
    }
}
